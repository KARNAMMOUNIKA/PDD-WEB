  "description": "Production-Ready Enterprise Mobile Automation Framework for Flutter Android APK using Appium 2.x, Node.js, Mocha, Mochawesome & ExcelJS",
  "main": "runner.js",
  "scripts": {
    "test": "node runner.js",
    "test:mocha": "mocha --config .mocharc.json",
    "test:300": "node runner.js",
