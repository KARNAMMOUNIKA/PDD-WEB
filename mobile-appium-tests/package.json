    "test:forms": "mocha --config .mocharc.json tests/02_forms.test.js",
    "test:ui": "mocha --config .mocharc.json tests/03_ui_components.test.js",
    "test:nav": "mocha --config .mocharc.json tests/04_navigation.test.js",
    "test:ai": "mocha --config .mocharc.json tests/05_ai_discovery.test.js"
  },
  "keywords": [
    "appium",
    "appium-2",
    "flutter",
    "android",
    "mobile-automation",
    "mocha",
    "chai",
    "mochawesome",
    "exceljs",
    "winston",
    "ci-cd",
    "github-actions"
  ],
  "author": "Senior Mobile QA Automation Architect",
  "license": "MIT",
  "dependencies": {
    "appium": "^2.5.1",
    "appium-flutter-driver": "^2.11.0",
    "appium-uiautomator2-driver": "^3.0.0",
    "chai": "^4.3.10",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "webdriverio": "^8.32.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "mocha": "^10.3.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
